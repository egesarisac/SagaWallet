# Docker Compose environment template
#
# Copy this file to .env to override variables used by Docker Compose.
#
# Notes:
# - The Go services do NOT automatically read .env files.
#   When running services with `go run`, configuration comes from each
#   service's `config/config.yaml` and/or your shell environment.
# - Docker Compose will automatically load a `.env` file from the project
#   directory for `${VAR}` substitutions.

# Postgres passwords used by docker-compose.yml and docker-compose.full.yml
WALLET_DB_PASSWORD=wallet_secret
TRANSACTION_DB_PASSWORD=transaction_secret

# Shared JWT secret used by docker-compose.full.yml (service containers)
JWT_SECRET=dev-local-jwt-secret-change-me

# Required internal service-to-service token used by wallet-service and transaction-service gRPC calls
WALLET_GRPC_TOKEN=dev-local-internal-grpc-token-change-me
