# Environment Configuration Template
# Copy this file to .env and fill in the values

# Database - Wallet Service
WALLET_DB_HOST=localhost
WALLET_DB_PORT=5432
WALLET_DB_USER=wallet_user
WALLET_DB_PASSWORD=wallet_secret
WALLET_DB_NAME=wallet_db
WALLET_DB_SSLMODE=disable

# Database - Transaction Service
TRANSACTION_DB_HOST=localhost
TRANSACTION_DB_PORT=5433
TRANSACTION_DB_USER=transaction_user
TRANSACTION_DB_PASSWORD=transaction_secret
TRANSACTION_DB_NAME=transaction_db
TRANSACTION_DB_SSLMODE=disable

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=go-fintech

# Service Ports
WALLET_HTTP_PORT=8081
WALLET_GRPC_PORT=9081
TRANSACTION_HTTP_PORT=8082
TRANSACTION_GRPC_PORT=9082
NOTIFICATION_HTTP_PORT=8083

# JWT (for future use)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
